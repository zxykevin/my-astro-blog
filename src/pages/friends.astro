---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

import { siteConfig } from "../config";
import { friends } from "../data/friends";

export const prerender = true;

if (!siteConfig.featurePages.friends) {
	return Astro.redirect("/404/");
}

const backgroundImages = [
	"/assets/desktop-banner/1.webp",
	"/assets/desktop-banner/2.webp",
	"/assets/desktop-banner/3.webp",
	"/assets/desktop-banner/4.webp",
];

const particles = Array.from({ length: 22 }, (_, index) => ({
	left: `${(index * 37) % 100}%`,
	top: `${(index * 61) % 100}%`,
	size: `${2 + (index % 3)}px`,
	duration: `${13 + (index % 6) * 2}s`,
	delay: `${index * -0.7}s`,
}));
---

<MainGridLayout
	title="友情链接"
	description="遇见有趣的灵魂与散落在互联网角落的星光。"
>
	<div class="friends-page">
		<div class="friends-scene" aria-hidden="true">
			<div class="friends-bg">
				{
					backgroundImages.map((image, index) => (
						<img
							class:list={[
								"friends-bg-image",
								{ active: index === 0 },
							]}
							src={image}
							alt=""
							loading={index === 0 ? "eager" : "lazy"}
							decoding="async"
						/>
					))
				}
			</div>
			<div class="friends-aurora"></div>
			<div class="friends-particles">
				{
					particles.map((particle) => (
						<i
							style={`--left:${particle.left};--top:${particle.top};--size:${particle.size};--duration:${particle.duration};--delay:${particle.delay}`}
						/>
					))
				}
			</div>
		</div>

		<div class="friends-content">
			<section class="friends-hero">
				<p class="friends-kicker">Friends / Link Exchange</p>
				<h1>友情链接</h1>
				<p class="friends-subtitle">
					遇见有趣的灵魂与散落在互联网角落的星光。
				</p>
			</section>

			<section class="friends-grid" aria-label="友情链接列表">
				{
					friends.map((friend) => {
						const hostname = new URL(friend.url).hostname;
						const isOnline =
							(friend.status ?? "online").toLowerCase() ===
							"online";

						return (
							<a
								class="friend-card"
								href={friend.url}
								target="_blank"
								rel="noopener noreferrer"
								aria-label={`访问 ${friend.name}`}
							>
								<span
									class="friend-card-glow"
									aria-hidden="true"
								/>
								<div class="friend-card-inner">
									<div class="friend-avatar-wrap">
										<img
											class="friend-avatar"
											src={friend.avatar}
											alt={`${friend.name} 头像`}
											loading="lazy"
											decoding="async"
										/>
										<span
											class:list={[
												"friend-status",
												isOnline
													? "is-online"
													: "is-idle",
											]}
											title={friend.status ?? "online"}
										/>
									</div>

									<div class="friend-info">
										<div class="friend-heading">
											<h2>{friend.name}</h2>
											<Icon
												name="material-symbols:arrow-outward-rounded"
												class="friend-link-icon"
											/>
										</div>
										<p class="friend-desc">
											{friend.description}
										</p>
										<span class="friend-host">
											{hostname}
										</span>
									</div>
								</div>
							</a>
						);
					})
				}
			</section>
		</div>
	</div>
</MainGridLayout>

<style>
	.friends-page {
		position: relative;
		isolation: isolate;
		min-height: calc(100vh - 8rem);
		overflow: hidden;
		border-radius: var(--radius-large);
		background: #060712;
		color: white;
		box-shadow: 0 24px 80px rgba(0, 0, 0, 0.32);
	}

	.friends-scene {
		position: absolute;
		inset: 0;
		z-index: 0;
		overflow: hidden;
		pointer-events: none;
	}

	.friends-bg,
	.friends-aurora,
	.friends-particles {
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.friends-bg {
		background: #060712;
	}

	.friends-bg-image {
		position: absolute;
		inset: -4%;
		width: 108%;
		height: 108%;
		object-fit: cover;
		filter: blur(18px) brightness(0.34) saturate(1.22);
		opacity: 0;
		transform: scale(1.04);
		transition:
			opacity 1800ms ease,
			transform 11000ms ease;
		will-change: opacity, transform;
	}

	.friends-bg-image.active {
		opacity: 1;
		transform: scale(1.1);
	}

	.friends-bg::after {
		content: "";
		position: absolute;
		inset: 0;
		background:
			radial-gradient(
				circle at 16% 14%,
				rgba(116, 95, 255, 0.28),
				transparent 34rem
			),
			radial-gradient(
				circle at 82% 18%,
				rgba(41, 221, 255, 0.18),
				transparent 28rem
			),
			linear-gradient(180deg, rgba(4, 5, 14, 0.42), rgba(3, 4, 12, 0.86));
	}

	.friends-aurora {
		z-index: 1;
		background:
			linear-gradient(
				115deg,
				transparent 10%,
				rgba(88, 166, 255, 0.13),
				transparent 34%
			),
			linear-gradient(
				250deg,
				transparent 20%,
				rgba(255, 123, 223, 0.12),
				transparent 46%
			);
		mix-blend-mode: screen;
		animation: auroraDrift 18s ease-in-out infinite alternate;
	}

	.friends-particles {
		z-index: 2;
		overflow: hidden;
	}

	.friends-particles i {
		position: absolute;
		left: var(--left);
		top: var(--top);
		width: var(--size);
		height: var(--size);
		border-radius: 999px;
		background: rgba(201, 231, 255, 0.72);
		box-shadow: 0 0 14px rgba(123, 206, 255, 0.7);
		animation: particleFloat var(--duration) linear infinite;
		animation-delay: var(--delay);
	}

	.friends-content {
		position: relative;
		z-index: 3;
		padding: clamp(2.75rem, 7vw, 6.5rem) clamp(1rem, 4vw, 2.25rem)
			clamp(3rem, 7vw, 5.5rem);
		animation: pageEnter 700ms ease-out both;
	}

	.friends-hero {
		max-width: 46rem;
		margin: 0 auto;
		text-align: center;
		text-shadow: 0 0 24px rgba(130, 168, 255, 0.42);
	}

	.friends-kicker {
		margin-bottom: 0.8rem;
		color: rgba(185, 225, 255, 0.72);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.friends-hero h1 {
		font-size: clamp(2.6rem, 9vw, 5.6rem);
		font-weight: 900;
		line-height: 1;
		letter-spacing: 0;
		background: linear-gradient(
			120deg,
			#ffffff 12%,
			#bfe8ff 42%,
			#f4c7ff 78%
		);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.friends-subtitle {
		max-width: 42rem;
		margin: 1.2rem auto 0;
		color: rgba(235, 245, 255, 0.78);
		font-size: clamp(1rem, 2.8vw, 1.22rem);
		line-height: 1.8;
	}

	.friends-grid {
		display: grid;
		grid-template-columns: repeat(1, minmax(0, 1fr));
		gap: 1.5rem;
		margin-top: clamp(2.5rem, 5vw, 4rem);
	}

	.friend-card {
		position: relative;
		min-height: 11.5rem;
		cursor: pointer;
		overflow: hidden;
		border: 1px solid rgba(198, 225, 255, 0.18);
		border-radius: 1.25rem;
		background:
			linear-gradient(
				135deg,
				rgba(255, 255, 255, 0.17),
				rgba(255, 255, 255, 0.055)
			),
			rgba(12, 15, 31, 0.42);
		box-shadow:
			0 18px 48px rgba(0, 0, 0, 0.28),
			inset 0 1px 0 rgba(255, 255, 255, 0.16);
		backdrop-filter: blur(22px) saturate(1.35);
		-webkit-backdrop-filter: blur(22px) saturate(1.35);
		transform: translate3d(var(--float-x, 0), var(--float-y, 0), 0);
		transition:
			transform 220ms ease,
			border-color 220ms ease,
			box-shadow 220ms ease,
			background 220ms ease;
	}

	.friend-card:hover {
		border-color: rgba(170, 222, 255, 0.58);
		box-shadow:
			0 24px 64px rgba(0, 0, 0, 0.34),
			0 0 34px rgba(99, 190, 255, 0.28),
			inset 0 1px 0 rgba(255, 255, 255, 0.22);
		transform: translate3d(
				var(--float-x, 0),
				calc(var(--float-y, 0) - 6px),
				0
			)
			scale(1.018);
	}

	.friend-card-glow {
		position: absolute;
		inset: -40%;
		background: radial-gradient(
			circle at var(--mx, 50%) var(--my, 50%),
			rgba(118, 213, 255, 0.24),
			transparent 34%
		);
		opacity: 0;
		transition: opacity 220ms ease;
	}

	.friend-card:hover .friend-card-glow {
		opacity: 1;
	}

	.friend-card-inner {
		position: relative;
		z-index: 1;
		display: flex;
		gap: 1rem;
		height: 100%;
		padding: 1.25rem;
	}

	.friend-avatar-wrap {
		position: relative;
		width: 4.7rem;
		height: 4.7rem;
		flex: 0 0 auto;
		border-radius: 1.15rem;
		padding: 2px;
		background: linear-gradient(
			135deg,
			rgba(165, 222, 255, 0.85),
			rgba(255, 174, 238, 0.62)
		);
		box-shadow: 0 0 22px rgba(133, 203, 255, 0.24);
	}

	.friend-avatar {
		width: 100%;
		height: 100%;
		border-radius: 1rem;
		object-fit: cover;
		transition: transform 260ms ease;
	}

	.friend-card:hover .friend-avatar {
		transform: scale(1.06);
	}

	.friend-status {
		position: absolute;
		right: -0.1rem;
		bottom: -0.1rem;
		width: 0.9rem;
		height: 0.9rem;
		border: 2px solid rgba(9, 12, 28, 0.86);
		border-radius: 999px;
		box-shadow: 0 0 12px currentColor;
	}

	.friend-status.is-online {
		color: #67f6b4;
		background: #67f6b4;
	}

	.friend-status.is-idle {
		color: #ffd36d;
		background: #ffd36d;
	}

	.friend-info {
		min-width: 0;
		flex: 1;
	}

	.friend-heading {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.friend-card h2 {
		color: rgba(255, 255, 255, 0.94);
		font-size: 1.05rem;
		font-weight: 850;
		line-height: 1.35;
		letter-spacing: 0;
	}

	.friend-link-icon {
		flex: 0 0 auto;
		margin-top: 0.1rem;
		color: rgba(196, 231, 255, 0.58);
		font-size: 1.25rem;
		transition:
			transform 220ms ease,
			color 220ms ease;
	}

	.friend-card:hover .friend-link-icon {
		color: #dff6ff;
		transform: translate(2px, -2px);
	}

	.friend-desc {
		min-height: 2.9rem;
		margin-top: 0.65rem;
		color: rgba(232, 244, 255, 0.7);
		font-size: 0.94rem;
		line-height: 1.65;
	}

	.friend-host {
		display: inline-flex;
		max-width: 100%;
		margin-top: 1rem;
		overflow: hidden;
		color: rgba(188, 229, 255, 0.64);
		font-size: 0.78rem;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	@media (min-width: 640px) {
		.friends-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1280px) {
		.friends-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (min-width: 1536px) {
		.friends-grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.friends-page {
			border-radius: 1rem;
		}

		.friend-card {
			min-height: 10.5rem;
			border-radius: 1rem;
		}

		.friend-card-inner {
			padding: 1rem;
		}

		.friend-avatar-wrap {
			width: 4rem;
			height: 4rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.friends-content,
		.friends-aurora,
		.friends-particles i,
		.friends-bg-image {
			animation: none;
			transition: none;
		}

		.friend-card,
		.friend-card:hover {
			transform: none;
		}
	}

	@keyframes pageEnter {
		from {
			opacity: 0;
			transform: translateY(18px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes auroraDrift {
		from {
			transform: translate3d(-2%, -1%, 0) scale(1);
			opacity: 0.68;
		}
		to {
			transform: translate3d(2%, 1%, 0) scale(1.05);
			opacity: 0.95;
		}
	}

	@keyframes particleFloat {
		from {
			transform: translate3d(0, 16vh, 0);
			opacity: 0;
		}
		15%,
		80% {
			opacity: 0.78;
		}
		to {
			transform: translate3d(22px, -110vh, 0);
			opacity: 0;
		}
	}
</style>

<script>
	const initFriendsPage = () => {
		const root = document.querySelector<HTMLElement>(".friends-page");
		if (!root || root.dataset.friendsReady === "true") {
			return;
		}

		root.dataset.friendsReady = "true";

		const motionQuery = window.matchMedia(
			"(prefers-reduced-motion: reduce)",
		);
		const slides = Array.from(
			root.querySelectorAll<HTMLImageElement>(".friends-bg-image"),
		);
		let activeIndex = slides.findIndex((slide) =>
			slide.classList.contains("active"),
		);

		if (activeIndex < 0) {
			activeIndex = 0;
			slides[0]?.classList.add("active");
		}

		if (!motionQuery.matches && slides.length > 1) {
			window.setInterval(() => {
				if (!root.isConnected) {
					return;
				}

				slides[activeIndex]?.classList.remove("active");
				activeIndex = (activeIndex + 1) % slides.length;
				slides[activeIndex]?.classList.add("active");
			}, 10000);
		}

		const cards = Array.from(
			root.querySelectorAll<HTMLAnchorElement>(".friend-card"),
		);
		const updateCard = (event: PointerEvent) => {
			const card = event.currentTarget;
			if (!(card instanceof HTMLAnchorElement)) {
				return;
			}

			const rect = card.getBoundingClientRect();
			const x = event.clientX - rect.left;
			const y = event.clientY - rect.top;
			card.style.setProperty("--mx", `${(x / rect.width) * 100}%`);
			card.style.setProperty("--my", `${(y / rect.height) * 100}%`);

			if (!motionQuery.matches) {
				card.style.setProperty(
					"--float-x",
					`${(x / rect.width - 0.5) * 8}px`,
				);
				card.style.setProperty(
					"--float-y",
					`${(y / rect.height - 0.5) * 8}px`,
				);
			}
		};

		cards.forEach((card) => {
			card.addEventListener("pointermove", updateCard);
			card.addEventListener("pointerleave", () => {
				card.style.setProperty("--float-x", "0px");
				card.style.setProperty("--float-y", "0px");
				card.style.setProperty("--mx", "50%");
				card.style.setProperty("--my", "50%");
			});
		});
	};

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initFriendsPage, {
			once: true,
		});
	} else {
		initFriendsPage();
	}

	document.addEventListener("astro:page-load", initFriendsPage);
</script>
