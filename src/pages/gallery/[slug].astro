---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getImage, Image } from "astro:assets";
import { Icon } from "astro-icon/components";

import { galleries, type Gallery } from "../../data/galleries";

export const prerender = true;

export const getStaticPaths = () =>
	galleries.map((gallery) => ({
		params: { slug: gallery.slug },
		props: { gallery },
	}));

interface Props {
	gallery: Gallery;
}

const { gallery } = Astro.props;
const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
	year: "numeric",
	month: "long",
	day: "numeric",
});

const formattedDate = dateFormatter.format(new Date(gallery.date));
const optimizedPhotos = await Promise.all(
	gallery.photos.map(async (photo) => ({
		...photo,
		lightbox: await getImage({
			src: photo.src,
			width: 1600,
			format: "webp",
			quality: 80,
		}),
	})),
);
---

<MainGridLayout
	title={`${gallery.title} - 图库`}
	description={gallery.description}
>
	<article class="gallery-detail" aria-labelledby="gallery-detail-title">
		<header class="gallery-detail-hero">
			<a class="gallery-back-link" href="/gallery/">
				<Icon
					name="material-symbols:arrow-back"
					class="gallery-back-icon"
				/>
				返回图库
			</a>
			<p class="gallery-kicker">Photo Album</p>
			<h1 id="gallery-detail-title">{gallery.title}</h1>
			<p class="gallery-description">{gallery.description}</p>
			<div class="gallery-info">
				<span>
					<Icon
						name="material-symbols:location-on"
						class="gallery-info-icon"
					/>
					{gallery.location}
				</span>
				<span>
					<Icon
						name="material-symbols:calendar-today"
						class="gallery-info-icon"
					/>
					{formattedDate}
				</span>
			</div>
			<div class="gallery-tags">
				{gallery.tags.map((tag) => <span>{tag}</span>)}
			</div>
		</header>

		<div class="photo-grid" aria-label={`${gallery.title} 图片列表`}>
			{
				optimizedPhotos.map((photo) => (
					<figure class="photo-card">
						<button
							class="photo-button"
							type="button"
							data-lightbox-src={photo.lightbox.src}
							data-lightbox-alt={photo.alt}
							data-lightbox-caption={photo.caption}
							data-lightbox-camera={photo.camera ?? ""}
							aria-label={`放大查看：${photo.alt}`}
						>
							<Image
								src={photo.src}
								alt={photo.alt}
								widths={[520, 800, 1200, 1600]}
								sizes="(max-width: 719px) 92vw, (max-width: 1179px) 44vw, 30vw"
								format="webp"
								quality={80}
								loading="lazy"
								decoding="async"
							/>
						</button>
						<figcaption>
							<span>{photo.caption}</span>
							{photo.camera && <em>{photo.camera}</em>}
						</figcaption>
					</figure>
				))
			}
		</div>
	</article>

	<div class="gallery-lightbox" data-gallery-lightbox hidden aria-hidden="true">
		<button
			class="gallery-lightbox-close"
			type="button"
			aria-label="关闭图片预览"
			data-lightbox-close
		>
			<Icon
				name="material-symbols:close"
				class="gallery-lightbox-close-icon"
			/>
		</button>
		<div class="gallery-lightbox-stage" data-lightbox-stage></div>
	</div>

	<script>
		type GalleryLightboxElement = HTMLElement & {
			__galleryAbortController?: AbortController;
		};

		type ActivePhoto = {
			src: string;
			alt: string;
		};

		const initGalleryDetail = () => {
			const lightbox = document.querySelector<GalleryLightboxElement>(
				"[data-gallery-lightbox]",
			);
			const lightboxStage = lightbox?.querySelector<HTMLElement>(
				"[data-lightbox-stage]",
			);
			const closeButton = document.querySelector<HTMLButtonElement>(
				"[data-lightbox-close]",
			);

			if (!lightbox || !lightboxStage) {
				return;
			}

			if (lightbox.parentElement !== document.body) {
				document.body.append(lightbox);
			}

			lightbox.__galleryAbortController?.abort();

			const controller = new AbortController();
			lightbox.__galleryAbortController = controller;
			const { signal } = controller;
			let activePhoto: ActivePhoto | null = null;

			const renderLightbox = () => {
				lightboxStage.replaceChildren();

				if (!activePhoto) {
					lightbox.hidden = true;
					lightbox.setAttribute("aria-hidden", "true");
					document.documentElement.classList.remove(
						"gallery-lightbox-open",
					);
					return;
				}

				const previewImage = document.createElement("img");
				previewImage.src = activePhoto.src;
				previewImage.alt = activePhoto.alt;
				previewImage.decoding = "async";
				previewImage.addEventListener(
					"click",
					(event) => {
						event.stopPropagation();
					},
					{ signal },
				);

				lightboxStage.append(previewImage);
				lightbox.hidden = false;
				lightbox.setAttribute("aria-hidden", "false");
				document.documentElement.classList.add(
					"gallery-lightbox-open",
				);
			};

			const closeLightbox = () => {
				activePhoto = null;
				renderLightbox();
			};

			document
				.querySelectorAll<HTMLButtonElement>("[data-lightbox-src]")
				.forEach((button) => {
					button.onclick = () => {
						const src = button.dataset.lightboxSrc;
						if (!src) {
							return;
						}

						activePhoto = {
							src,
							alt: button.dataset.lightboxAlt ?? "",
						};
						renderLightbox();
					};
				});

			closeButton?.addEventListener(
				"click",
				(event) => {
					event.preventDefault();
					event.stopPropagation();
					closeLightbox();
				},
				{ signal },
			);
			lightbox.addEventListener("click", closeLightbox, { signal });
			document.addEventListener(
				"keydown",
				(event) => {
					if (
						event.key === "Escape" &&
						lightbox.getAttribute("aria-hidden") === "false"
					) {
						closeLightbox();
					}
				},
				{ signal },
			);
		};

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", initGalleryDetail, {
				once: true,
			});
		} else {
			initGalleryDetail();
		}

		document.addEventListener("astro:page-load", initGalleryDetail);
	</script>
</MainGridLayout>

<style>
	.gallery-detail {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		border-radius: var(--radius-large);
		padding: clamp(1.25rem, 4vw, 2.5rem);
		background:
			radial-gradient(
				circle at 12% 8%,
				rgba(124, 214, 255, 0.24),
				transparent 28rem
			),
			radial-gradient(
				circle at 86% 16%,
				rgba(255, 155, 218, 0.16),
				transparent 26rem
			),
			linear-gradient(
				145deg,
				rgba(11, 16, 36, 0.8),
				rgba(20, 22, 48, 0.54)
			);
		box-shadow: 0 24px 80px rgba(0, 0, 0, 0.24);
		color: rgba(255, 255, 255, 0.92);
		backdrop-filter: blur(18px) saturate(1.2);
		-webkit-backdrop-filter: blur(18px) saturate(1.2);
	}

	.gallery-detail-hero {
		max-width: 48rem;
		margin-bottom: clamp(1.75rem, 4vw, 2.75rem);
	}

	.gallery-back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		margin-bottom: 1.2rem;
		border: 1px solid rgba(188, 226, 255, 0.22);
		border-radius: 999px;
		padding: 0.45rem 0.78rem;
		background: rgba(255, 255, 255, 0.08);
		color: rgba(236, 248, 255, 0.78);
		font-size: 0.86rem;
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			background 180ms ease;
	}

	.gallery-back-link:hover {
		border-color: rgba(188, 226, 255, 0.5);
		background: rgba(255, 255, 255, 0.13);
		transform: translateX(-2px);
	}

	.gallery-back-icon {
		font-size: 1rem;
	}

	.gallery-kicker {
		margin-bottom: 0.65rem;
		color: rgba(190, 229, 255, 0.74);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.gallery-detail h1 {
		font-size: clamp(2.2rem, 7vw, 4.5rem);
		font-weight: 900;
		line-height: 1.03;
		letter-spacing: 0;
		background: linear-gradient(120deg, #fff, #bfe8ff 48%, #ffd3ef);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.gallery-description {
		margin-top: 1rem;
		color: rgba(239, 247, 255, 0.76);
		font-size: 1rem;
		line-height: 1.8;
	}

	.gallery-info {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem 1rem;
		margin-top: 1.15rem;
		color: rgba(213, 237, 255, 0.72);
		font-size: 0.92rem;
	}

	.gallery-info span {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
	}

	.gallery-info-icon {
		font-size: 1.1rem;
	}

	.gallery-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-top: 1rem;
	}

	.gallery-tags span {
		border: 1px solid rgba(184, 226, 255, 0.24);
		border-radius: 999px;
		padding: 0.28rem 0.62rem;
		background: rgba(255, 255, 255, 0.08);
		color: rgba(238, 248, 255, 0.78);
		font-size: 0.78rem;
	}

	.photo-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		align-items: start;
	}

	.photo-card {
		overflow: hidden;
		border: 1px solid rgba(204, 230, 255, 0.16);
		border-radius: 1rem;
		background:
			linear-gradient(
				135deg,
				rgba(255, 255, 255, 0.14),
				rgba(255, 255, 255, 0.055)
			),
			rgba(8, 12, 28, 0.42);
		box-shadow:
			0 16px 42px rgba(0, 0, 0, 0.23),
			inset 0 1px 0 rgba(255, 255, 255, 0.14);
		backdrop-filter: blur(18px) saturate(1.3);
		-webkit-backdrop-filter: blur(18px) saturate(1.3);
	}

	.photo-button {
		position: relative;
		display: block;
		width: 100%;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background:
			linear-gradient(135deg, rgba(123, 205, 255, 0.18), transparent),
			rgba(255, 255, 255, 0.07);
		cursor: zoom-in;
	}

	.photo-button img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition:
			transform 300ms ease,
			filter 300ms ease;
	}

	.photo-card:hover .photo-button img {
		filter: brightness(1.05);
		transform: scale(1.045);
	}

	.photo-card figcaption {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 0.85rem 0.95rem 1rem;
		color: rgba(238, 248, 255, 0.74);
		font-size: 0.92rem;
		line-height: 1.6;
	}

	.photo-card figcaption em {
		color: rgba(202, 230, 255, 0.56);
		font-size: 0.78rem;
		font-style: normal;
	}

	.gallery-lightbox {
		position: fixed;
		inset: 0;
		width: 100vw;
		height: 100vh;
		z-index: 9999;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(0, 0, 0, 0.75);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		view-transition-name: none;
	}

	.gallery-lightbox[hidden] {
		display: none;
	}

	.gallery-lightbox-stage {
		display: contents;
		view-transition-name: none;
	}

	.gallery-lightbox-stage img {
		display: block;
		max-width: 92vw;
		max-height: 86vh;
		width: auto;
		height: auto;
		object-fit: contain;
		border-radius: 16px;
		view-transition-name: none;
	}

	.gallery-lightbox-close {
		position: fixed;
		top: max(1rem, env(safe-area-inset-top));
		right: max(1rem, env(safe-area-inset-right));
		display: grid;
		width: 2.75rem;
		height: 2.75rem;
		place-items: center;
		border: 1px solid rgba(217, 239, 255, 0.2);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.13);
		color: white;
		box-shadow: 0 14px 42px rgba(0, 0, 0, 0.28);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		transition: background 180ms ease;
	}

	.gallery-lightbox-close:hover {
		background: rgba(255, 255, 255, 0.2);
	}

	.gallery-lightbox-close-icon {
		font-size: 1.35rem;
	}

	@media (min-width: 720px) {
		.photo-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1180px) {
		.photo-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.gallery-detail,
		.photo-card,
		.gallery-lightbox-stage img {
			border-radius: 1rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.gallery-back-link,
		.photo-button img {
			transition: none;
		}
	}

	:global(html.gallery-lightbox-open) {
		overflow: hidden;
	}
</style>
