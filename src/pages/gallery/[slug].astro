---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getImage, Image } from "astro:assets";
import { Icon } from "astro-icon/components";

import { galleries, type Gallery } from "../../data/galleries";

export const prerender = true;

export const getStaticPaths = () =>
	galleries.map((gallery) => ({
		params: { slug: gallery.slug },
		props: { gallery },
	}));

interface Props {
	gallery: Gallery;
}

const { gallery } = Astro.props;
const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
	year: "numeric",
	month: "long",
	day: "numeric",
});

const formattedDate = dateFormatter.format(new Date(gallery.date));
const optimizedPhotos = await Promise.all(
	gallery.photos.map(async (photo) => ({
		...photo,
		lightbox: await getImage({
			src: photo.src,
			width: 1600,
			format: "webp",
			quality: 80,
		}),
	})),
);
---

<MainGridLayout
	title={`${gallery.title} - 图库`}
	description={gallery.description}
>
	<article class="gallery-detail" aria-labelledby="gallery-detail-title">
		<header class="gallery-detail-hero">
			<a class="gallery-back-link" href="/gallery/">
				<Icon
					name="material-symbols:arrow-back"
					class="gallery-back-icon"
				/>
				返回图库
			</a>
			<p class="gallery-kicker">Photo Album</p>
			<h1 id="gallery-detail-title">{gallery.title}</h1>
			<p class="gallery-description">{gallery.description}</p>
			<div class="gallery-info">
				<span>
					<Icon
						name="material-symbols:location-on"
						class="gallery-info-icon"
					/>
					{gallery.location}
				</span>
				<span>
					<Icon
						name="material-symbols:calendar-today"
						class="gallery-info-icon"
					/>
					{formattedDate}
				</span>
			</div>
			<div class="gallery-tags">
				{gallery.tags.map((tag) => <span>{tag}</span>)}
			</div>
		</header>

		<div class="photo-grid" aria-label={`${gallery.title} 图片列表`}>
			{
				optimizedPhotos.map((photo) => (
					<figure class="photo-card">
						<button
							class="photo-button"
							type="button"
							data-fancybox={`gallery-${gallery.slug}`}
							data-src={photo.lightbox.src}
							data-type="image"
							data-caption={photo.caption}
							aria-label={`放大查看：${photo.alt}`}
						>
							<Image
								src={photo.src}
								alt={photo.alt}
								widths={[520, 800, 1200, 1600]}
								sizes="(max-width: 719px) 92vw, (max-width: 1179px) 44vw, 30vw"
								format="webp"
								quality={80}
								loading="lazy"
								decoding="async"
							/>
						</button>
						<figcaption>
							<span>{photo.caption}</span>
							{photo.camera && <em>{photo.camera}</em>}
						</figcaption>
					</figure>
				))
			}
		</div>
	</article>
</MainGridLayout>

<style>
	.gallery-detail {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		border-radius: var(--radius-large);
		padding: clamp(1.25rem, 4vw, 2.5rem);
		background:
			radial-gradient(
				circle at 12% 8%,
				rgba(124, 214, 255, 0.24),
				transparent 28rem
			),
			radial-gradient(
				circle at 86% 16%,
				rgba(255, 155, 218, 0.16),
				transparent 26rem
			),
			linear-gradient(
				145deg,
				rgba(11, 16, 36, 0.8),
				rgba(20, 22, 48, 0.54)
			);
		box-shadow: 0 24px 80px rgba(0, 0, 0, 0.24);
		color: rgba(255, 255, 255, 0.92);
		backdrop-filter: blur(18px) saturate(1.2);
		-webkit-backdrop-filter: blur(18px) saturate(1.2);
	}

	.gallery-detail-hero {
		max-width: 48rem;
		margin-bottom: clamp(1.75rem, 4vw, 2.75rem);
	}

	.gallery-back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		margin-bottom: 1.2rem;
		border: 1px solid rgba(188, 226, 255, 0.22);
		border-radius: 999px;
		padding: 0.45rem 0.78rem;
		background: rgba(255, 255, 255, 0.08);
		color: rgba(236, 248, 255, 0.78);
		font-size: 0.86rem;
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			background 180ms ease;
	}

	.gallery-back-link:hover {
		border-color: rgba(188, 226, 255, 0.5);
		background: rgba(255, 255, 255, 0.13);
		transform: translateX(-2px);
	}

	.gallery-back-icon {
		font-size: 1rem;
	}

	.gallery-kicker {
		margin-bottom: 0.65rem;
		color: rgba(190, 229, 255, 0.74);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.gallery-detail h1 {
		font-size: clamp(2.2rem, 7vw, 4.5rem);
		font-weight: 900;
		line-height: 1.03;
		letter-spacing: 0;
		background: linear-gradient(120deg, #fff, #bfe8ff 48%, #ffd3ef);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.gallery-description {
		margin-top: 1rem;
		color: rgba(239, 247, 255, 0.76);
		font-size: 1rem;
		line-height: 1.8;
	}

	.gallery-info {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem 1rem;
		margin-top: 1.15rem;
		color: rgba(213, 237, 255, 0.72);
		font-size: 0.92rem;
	}

	.gallery-info span {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
	}

	.gallery-info-icon {
		font-size: 1.1rem;
	}

	.gallery-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-top: 1rem;
	}

	.gallery-tags span {
		border: 1px solid rgba(184, 226, 255, 0.24);
		border-radius: 999px;
		padding: 0.28rem 0.62rem;
		background: rgba(255, 255, 255, 0.08);
		color: rgba(238, 248, 255, 0.78);
		font-size: 0.78rem;
	}

	.photo-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		align-items: start;
	}

	.photo-card {
		overflow: hidden;
		border: 1px solid rgba(204, 230, 255, 0.16);
		border-radius: 1rem;
		background:
			linear-gradient(
				135deg,
				rgba(255, 255, 255, 0.14),
				rgba(255, 255, 255, 0.055)
			),
			rgba(8, 12, 28, 0.42);
		box-shadow:
			0 16px 42px rgba(0, 0, 0, 0.23),
			inset 0 1px 0 rgba(255, 255, 255, 0.14);
		backdrop-filter: blur(18px) saturate(1.3);
		-webkit-backdrop-filter: blur(18px) saturate(1.3);
	}

	.photo-button {
		position: relative;
		display: block;
		width: 100%;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background:
			linear-gradient(135deg, rgba(123, 205, 255, 0.18), transparent),
			rgba(255, 255, 255, 0.07);
		cursor: zoom-in;
	}

	.photo-button img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition:
			transform 300ms ease,
			filter 300ms ease;
	}

	.photo-card:hover .photo-button img {
		filter: brightness(1.05);
		transform: scale(1.045);
	}

	.photo-card figcaption {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 0.85rem 0.95rem 1rem;
		color: rgba(238, 248, 255, 0.74);
		font-size: 0.92rem;
		line-height: 1.6;
	}

	.photo-card figcaption em {
		color: rgba(202, 230, 255, 0.56);
		font-size: 0.78rem;
		font-style: normal;
	}

	@media (min-width: 720px) {
		.photo-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1180px) {
		.photo-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.gallery-detail,
		.photo-card {
			border-radius: 1rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.gallery-back-link,
		.photo-button img {
			transition: none;
		}
	}
</style>
